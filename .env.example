# ───────────────────────────────────────────────────────────────
# Upstock — ROOT env for docker compose (infra). Copy to `.env`.
# App-level config lives in apps/api/.env (see apps/api/.env.example).
# ───────────────────────────────────────────────────────────────

# Postgres (consumed by the `db` service and the API connection string)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=upstock
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Published app ports
API_PORT=3001
WEB_PORT=3000
