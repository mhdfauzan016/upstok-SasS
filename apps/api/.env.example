# ─────────────────────────────────────────────────────────────
# Upstock API — environment variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# --- Database (PostgreSQL / Prisma) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://upstock:upstock@localhost:5432/upstock?schema=public"

# --- App ---
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# --- Multi-tenant domain ---
ROOT_DOMAIN=upstock.my.id
ADMIN_SUBDOMAIN=admin

# --- Auth / JWT ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=30d

# --- Redis (tenant cache, sessions, rate limiting) ---
REDIS_URL=redis://localhost:6379

# --- CORS (comma-separated origins; * wildcards per environment) ---
CORS_ORIGINS=http://localhost:3000
