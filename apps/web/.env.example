# Upstock web (Vite) — copy to .env. All client vars must be VITE_-prefixed.

# Base URL of the NestJS API
VITE_API_URL=http://localhost:3001/api/v1

# Tenant used when no subdomain is present (localhost / SSR fallback)
VITE_DEFAULT_TENANT=acme

# Root domain used to extract the tenant subdomain in production
VITE_ROOT_DOMAIN=upstock.my.id
